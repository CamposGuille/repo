'use client'

import { useState, useEffect, useRef } from 'react'
import { useParams, useRouter } from 'next/navigation'
import { Card, CardContent } from '@/components/ui/card'
import { Loader2, Clock, Monitor as MonitorIcon, Volume2, VolumeX } from 'lucide-react'
import { Button } from '@/components/ui/button'

interface TurnoActivo {
  id: string
  numero: string
  estado: string
  fechaLlamado: string
  sector: {
    id: string
    nombre: string
    color: string
  }
  box?: {
    id: string
    nombre: string
  } | null
  operador: {
    nombre: string
  }
}

interface TurnoAusente {
  id: string
  numero: string
}

interface TurnoAnterior {
  id: string
  numero: string
  estado: string
  fechaFinalizado: string | null
  sector: {
    nombre: string
    color: string
  }
}

interface SectorAsignado {
  id: string
  nombre: string
  color: string
}

interface MonitorData {
  id: string
  numero: number
  nombre: string
  descripcion?: string
  sectores?: { sector: SectorAsignado }[]
  videos?: VideoAsignado[]
}

interface VideoAsignado {
  id: string
  nombre: string
  ruta: string
  orden: number
}

const playDingDong = () => {
  try {
    const audioContext = new (window.AudioContext || (window as any).webkitAudioContext())

    // DING
    const oscillator1 = audioContext.createOscillator()
    const gainNode1 = audioContext.createGain()
    oscillator1.connect(gainNode1)
    gainNode1.connect(audioContext.destination)
    oscillator1.frequency.value = 830.61
    oscillator1.type = 'sine'
    gainNode1.gain.setValueAtTime(0, audioContext.currentTime)
    gainNode1.gain.linearRampToValueAtTime(0.4, audioContext.currentTime + 0.02)
    gainNode1.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 1.0)
    oscillator1.start(audioContext.currentTime)
    oscillator1.stop(audioContext.currentTime + 1.0)

    // DONG
    const oscillator2 = audioContext.createOscillator()
    const gainNode2 = audioContext.createGain()
    oscillator2.connect(gainNode2)
    gainNode2.connect(audioContext.destination)
    oscillator2.frequency.value = 587.33
    oscillator2.type = 'sine'
    gainNode2.gain.setValueAtTime(0, audioContext.currentTime + 0.25)
    gainNode2.gain.linearRampToValueAtTime(0.4, audioContext.currentTime + 0.27)
    gainNode2.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 1.5)
    oscillator2.start(audioContext.currentTime + 0.25)
    oscillator2.stop(audioContext.currentTime + 1.5)

    // Armónicos
    const harmonic1 = audioContext.createOscillator()
    const gainH1 = audioContext.createGain()
    harmonic1.connect(gainH1)
    gainH1.connect(audioContext.destination)
    harmonic1.frequency.value = 830.61 * 2
    harmonic1.type = 'sine'
    gainH1.gain.setValueAtTime(0, audioContext.currentTime)
    gainH1.gain.linearRampToValueAtTime(0.15, audioContext.currentTime + 0.02)
    gainH1.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.6)
    harmonic1.start(audioContext.currentTime)
    harmonic1.stop(audioContext.currentTime + 0.6)

  } catch (error) {
    console.error('Error al reproducir Ding Dong:', error)
  }
}

const playCustomSound = (soundUrl: string): Promise<void> => {
  return new Promise((resolve, reject) => {
    try {
      const audio = new Audio(soundUrl)
      audio.play()
        .then(() => {
          audio.onended = () => resolve()
        })
        .catch((error) => {
          reject(error)
        })
      audio.onerror = (e) => {
        reject(e)
      }
    } catch (error) {
      reject(error)
    }
  })
}

// Componente para reproducir videos en rotación continua
function VideoPlayer({ videos, fillContainer = false }: { videos: VideoAsignado[], fillContainer?: boolean }) {
  const [currentIndex, setCurrentIndex] = useState(0)
  const videoRef = useRef<HTMLVideoElement>(null)

  const handleVideoEnd = () => {
    setCurrentIndex((prev) => (prev + 1) % videos.length)
  }

  useEffect(() => {
    if (videoRef.current) {
      videoRef.current.load()
      videoRef.current.play().catch(() => {})
    }
  }, [currentIndex])

  if (videos.length === 0) return null

  const currentVideo = videos[currentIndex]

  return (
    <video
      ref={videoRef}
      className={`w-full h-full ${fillContainer ? 'object-cover' : 'object-contain'}`}
      autoPlay
      muted
      onEnded={handleVideoEnd}
      playsInline
    >
      <source src={`/api/videos/stream?video=${encodeURIComponent(currentVideo.ruta)}`} type="video/mp4" />
      Tu navegador no soporta el elemento de video.
    </video>
  )
}

export default function MonitorPage() {
  const params = useParams()
  const router = useRouter()
  const numeroParam = params.numero as string[] | undefined
  const monitorNumero = numeroParam?.[0] || null

  const [turnosActivos, setTurnosActivos] = useState<TurnoActivo[]>([])
  const [turnosAusentes, setTurnosAusentes] = useState<TurnoAusente[]>([])
  const [loading, setLoading] = useState(true)
  const [monitores, setMonitores] = useState<MonitorData[]>([])
  const [monitorData, setMonitorData] = useState<MonitorData | null>(null)
  const [sectoresAsignados, setSectoresAsignados] = useState<SectorAsignado[]>([])
  const turnosBeepedRef = useRef<Set<string>>(new Set())

  const [textosConfiguracion, setTextosConfiguracion] = useState<any>(null)
  const [monitorSonidoUrl, setMonitorSonidoUrl] = useState<string | null>(null)
  const monitorSonidoUrlRef = useRef<string | null>(null)
  
  const [audioEnabled, setAudioEnabled] = useState(false)
  const [videosAsignados, setVideosAsignados] = useState<VideoAsignado[]>([])
  
  // Refs para controlar la navegación
  const mountedRef = useRef(false)
  const monitorCargadoRef = useRef(false)
  const monitorActualRef = useRef<string | null>(null)

  const unlockAudio = async () => {
    try {
      const audioContext = new (window.AudioContext || (window as any).webkitAudioContext())
      if (audioContext.state === 'suspended') {
        await audioContext.resume()
      }
      const oscillator = audioContext.createOscillator()
      const gainNode = audioContext.createGain()
      oscillator.connect(gainNode)
      gainNode.connect(audioContext.destination)
      gainNode.gain.value = 0
      oscillator.start()
      oscillator.stop(audioContext.currentTime + 0.001)
      setAudioEnabled(true)
    } catch (error) {
      console.error('Error al desbloquear audio:', error)
    }
  }

  // Cargar lista de monitores (selector)
  useEffect(() => {
    if (monitorNumero || mountedRef.current) return
    
    const cargarMonitores = async () => {
      try {
        const response = await fetch('/api/admin/monitores')
        const data = await response.json()
        if (response.ok) {
          setMonitores(data)
        }
      } catch (error) {
        console.error('Error al cargar monitores:', error)
      } finally {
        setLoading(false)
      }
    }
    
    cargarMonitores()
    mountedRef.current = true
  }, [monitorNumero])

  // Cargar configuración
  useEffect(() => {
    const cargarConfiguracion = async () => {
      try {
        const response = await fetch('/api/admin/configuracion')
        const data = await response.json()
        if (response.ok) {
          setTextosConfiguracion(data)
          const sonidoUrl = data.monitorSonidoUrl || null
          setMonitorSonidoUrl(sonidoUrl)
          monitorSonidoUrlRef.current = sonidoUrl
        }
      } catch (error) {
        console.error('Error al cargar configuración:', error)
      }
    }
    cargarConfiguracion()
  }, [])

  // Cargar monitor específico
  useEffect(() => {
    if (!monitorNumero || monitorActualRef.current === monitorNumero) return
    
    const cargarMonitor = async () => {
      setLoading(true)
      monitorCargadoRef.current = false
      
      try {
        const response = await fetch(`/api/admin/monitores/numero/${monitorNumero}`)
        const data = await response.json()
        
        if (response.ok && data) {
          setMonitorData(data)
          monitorActualRef.current = monitorNumero
          monitorCargadoRef.current = true
          
          if (data.sectores) {
            setSectoresAsignados(data.sectores.map((ms: any) => ms.sector))
          }
          
          if (data.videos && data.videos.length > 0) {
            setVideosAsignados(data.videos)
          } else if (data.id) {
            try {
              const videosResponse = await fetch(`/api/admin/monitores/${data.id}/videos`)
              if (videosResponse.ok) {
                const videos = await videosResponse.json()
                setVideosAsignados(videos || [])
              }
            } catch (e) {
              console.error('Error al cargar videos:', e)
            }
          }
        }
      } catch (error) {
        console.error('Error al cargar monitor:', error)
      } finally {
        setLoading(false)
      }
    }
    
    cargarMonitor()
  }, [monitorNumero])

  // Cargar ausentes (solo para monitor Prueba)
  useEffect(() => {
    if (!monitorNumero || monitorNumero !== '4') return
    
    const cargarAusentes = async () => {
      try {
        const response = await fetch('/api/turnos/ausentes')
        const data = await response.json()
        if (response.ok) {
          setTurnosAusentes(data)
        }
      } catch (error) {
        console.error('Error al cargar ausentes:', error)
      }
    }
    
    cargarAusentes()
  }, [monitorNumero])

  // Cargar turnos activos
  useEffect(() => {
    if (sectoresAsignados.length === 0 || !monitorNumero) return
    
    const cargarTurnos = async () => {
      try {
        const response = await fetch('/api/turnos/activos')
        const data = await response.json()

        if (response.ok) {
          const turnosFiltrados = data.filter((turno: TurnoActivo) =>
            sectoresAsignados.some((sector: SectorAsignado) =>
              sector.id === turno.sector.id
            )
          )

          const nuevosTurnosLlamados = turnosFiltrados.filter(
            (turno: TurnoActivo) =>
              turno.estado === 'llamado' && !turnosBeepedRef.current.has(turno.id)
          )

          if (nuevosTurnosLlamados.length > 0 && audioEnabled) {
            nuevosTurnosLlamados.forEach((turno: TurnoActivo) => {
              turnosBeepedRef.current.add(turno.id)
            })
            
            const sonidoUrl = monitorSonidoUrlRef.current
            if (sonidoUrl) {
              playCustomSound(sonidoUrl).catch(() => playDingDong())
            } else {
              playDingDong()
            }
          }

          setTurnosActivos(turnosFiltrados)
        }
      } catch (error) {
        console.error('Error al cargar turnos activos:', error)
      }
    }
    
    cargarTurnos()
  }, [sectoresAsignados, audioEnabled, monitorNumero])

  // Polling de turnos
  useEffect(() => {
    if (sectoresAsignados.length === 0 || !monitorNumero) return
    
    const interval = setInterval(async () => {
      try {
        // Cargar turnos activos
        const response = await fetch('/api/turnos/activos')
        const data = await response.json()

        if (response.ok) {
          const turnosFiltrados = data.filter((turno: TurnoActivo) =>
            sectoresAsignados.some((sector: SectorAsignado) =>
              sector.id === turno.sector.id
            )
          )

          const nuevosTurnosLlamados = turnosFiltrados.filter(
            (turno: TurnoActivo) =>
              turno.estado === 'llamado' && !turnosBeepedRef.current.has(turno.id)
          )

          if (nuevosTurnosLlamados.length > 0 && audioEnabled) {
            nuevosTurnosLlamados.forEach((turno: TurnoActivo) => {
              turnosBeepedRef.current.add(turno.id)
            })
            
            const sonidoUrl = monitorSonidoUrlRef.current
            if (sonidoUrl) {
              playCustomSound(sonidoUrl).catch(() => playDingDong())
            } else {
              playDingDong()
            }
          }

          setTurnosActivos(turnosFiltrados)
        }

        // Cargar ausentes solo para monitor Prueba (número 4)
        if (monitorNumero === '4') {
          const ausentesResponse = await fetch('/api/turnos/ausentes')
          if (ausentesResponse.ok) {
            const ausentesData = await ausentesResponse.json()
            setTurnosAusentes(ausentesData)
          }
        }
      } catch (error) {
        console.error('Error al cargar turnos activos:', error)
      }
    }, 10000)
    
    return () => clearInterval(interval)
  }, [sectoresAsignados, audioEnabled, monitorNumero])

  const handleSeleccionarMonitor = (monitor: MonitorData) => {
    router.push(`/monitor/${monitor.numero}`)
  }

  const handleVolver = () => {
    monitorActualRef.current = null
    monitorCargadoRef.current = false
    setMonitorData(null)
    setSectoresAsignados([])
    setVideosAsignados([])
    setTurnosActivos([])
    setTurnosAusentes([])
    router.push('/monitor')
  }

  // Pantalla de carga
  if (loading && monitorNumero && !monitorData) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 flex items-center justify-center">
        <Loader2 className="w-16 h-16 animate-spin text-primary" />
      </div>
    )
  }

  // SELECTOR DE MONITORES
  if (!monitorNumero) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 flex items-center justify-center p-4">
        <Card className="bg-white/10 backdrop-blur-sm border-white/20 max-w-4xl mx-auto w-full">
          <CardContent className="p-8 md:p-12">
            <div className="text-center mb-8">
              {textosConfiguracion?.totemLogoUrl ? (
                <img
                  src={textosConfiguracion.totemLogoUrl}
                  alt="Logo Institución"
                  className="h-16 md:h-20 mx-auto mb-6 object-contain"
                  onError={(e) => {
                    e.currentTarget.style.display = 'none'
                  }}
                />
              ) : (
                <MonitorIcon className="w-24 h-24 mx-auto mb-6 text-primary" />
              )}
              <h1 className="text-4xl md:text-5xl font-bold text-white mb-4">
                {textosConfiguracion?.monitorTitulo || 'Monitor de Turnos'}
              </h1>
              <p className="text-slate-400 text-lg">
                {textosConfiguracion?.monitorSubtitulo || 'Espere en la sala a ser llamado'}
              </p>
            </div>

            {loading ? (
              <div className="flex justify-center py-12">
                <Loader2 className="w-12 h-12 animate-spin text-primary" />
              </div>
            ) : monitores.length === 0 ? (
              <div className="text-center py-12">
                <Clock className="w-16 h-16 mx-auto mb-4 text-slate-400" />
                <p className="text-slate-300 text-lg mb-2">
                  No hay monitores configurados
                </p>
                <p className="text-slate-400 text-sm">
                  Inicie sesión en el panel de administración para crear monitores.
                </p>
              </div>
            ) : (
              <div className="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                {monitores.map((monitor) => (
                  <button
                    key={monitor.id}
                    onClick={() => handleSeleccionarMonitor(monitor)}
                    className="p-6 rounded-lg text-left transition-all border-2 bg-white/5 hover:bg-white/10 border-white/20 hover:border-primary/50 hover:shadow-lg hover:shadow-primary/20"
                  >
                    <div className="font-semibold text-white text-lg mb-1">
                      {monitor.nombre}
                    </div>
                    {monitor.descripcion && (
                      <div className="text-slate-300 text-sm">
                        {monitor.descripcion}
                      </div>
                    )}
                  </button>
                ))}
              </div>
            )}
          </CardContent>
        </Card>
      </div>
    )
  }

  // Determinar si mostrar videos
  const mostrarVideos = videosAsignados.length > 0
  
  // Detectar si es el monitor Prueba (número 4 con videos)
  const esMonitorPrueba = monitorNumero === '4' && mostrarVideos

  // MONITOR PRUEBA - DISEÑO ESPECIAL (SOLO MONITOR 4 CON VIDEOS)
  // Video pegado al borde superior, Turnos pegados al borde inferior
  if (esMonitorPrueba) {
    // Limitar ausentes a los últimos 20 para que llenen el recuadro
    const ausentesLimitados = turnosAusentes.slice(0, 20)
    
    return (
      <div className="h-screen w-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 flex flex-col overflow-hidden">
        {/* Sección superior: Video + Ausentes */}
        <div className="flex items-start" style={{ height: '45%' }}>
          {/* Botón de sonido - Arriba a la derecha, pegado a los bordes */}
          <button
            onClick={() => audioEnabled ? setAudioEnabled(false) : unlockAudio()}
            className={`absolute top-0 right-0 z-10 w-8 h-8 flex items-center justify-center ${
              audioEnabled 
                ? 'bg-green-500 hover:bg-green-600' 
                : 'bg-red-500 hover:bg-red-600'
            }`}
          >
            {audioEnabled ? (
              <Volume2 className="w-5 h-5 text-white" />
            ) : (
              <VolumeX className="w-5 h-5 text-white" />
            )}
          </button>
          
          {/* Video - Arriba a la izquierda, proporción 16:9 */}
          <div className="aspect-video h-full flex-shrink-0">
            <video
              className="w-full h-full object-contain"
              autoPlay
              muted
              loop
              playsInline
            >
              <source src={`/api/videos/stream?video=${encodeURIComponent(videosAsignados[0]?.ruta || '')}`} type="video/mp4" />
            </video>
          </div>
          
          {/* Ausentes - Centrado en la zona libre restante */}
          <div className="flex-1 flex items-center justify-center p-2">
            <div className="border-2 border-white/30 rounded-lg p-3 flex flex-col items-center justify-start overflow-hidden" 
                 style={{ width: '100%', height: '100%', maxWidth: '400px', maxHeight: 'calc(45vh - 20px)' }}>
              <span className="text-white font-bold text-sm text-center mb-2 border-b border-white/20 pb-2 w-full flex-shrink-0">AUSENTES</span>
              <div className="flex flex-wrap gap-2 justify-center content-start overflow-y-auto w-full" style={{ maxHeight: 'calc(100% - 40px)' }}>
                {ausentesLimitados.length === 0 ? (
                  <span className="text-white/50 text-sm text-center">Sin ausentes</span>
                ) : (
                  ausentesLimitados.map((ausente) => (
                    <span
                      key={ausente.id}
                      className="px-3 py-1 border-2 border-red-500 text-red-400 rounded font-bold text-base"
                    >
                      {ausente.numero}
                    </span>
                  ))
                )}
              </div>
            </div>
          </div>
        </div>

        {/* TURNOS - Zona principal, pegados al borde inferior */}
        <div className="flex-1 flex items-end justify-center pb-3 px-2">
          {turnosActivos.length === 0 ? (
            <div className="flex items-center justify-center py-8">
              <Clock className="w-12 h-12 text-slate-400" />
            </div>
          ) : (
            <div className="flex gap-3 w-full items-end justify-center">
              {turnosActivos.map((turno) => (
                <Card
                  key={turno.id}
                  className="overflow-hidden shadow-2xl border-2 relative flex flex-col"
                  style={{
                    borderColor: turno.sector.color,
                    backgroundColor: 'rgba(255,255,255,0.95)',
                    width: turnosActivos.length === 1 ? 'auto' : 
                           turnosActivos.length === 2 ? '48%' : 
                           turnosActivos.length === 3 ? '32%' : '24%',
                    minWidth: turnosActivos.length === 1 ? '500px' : '320px',
                    maxWidth: turnosActivos.length === 1 ? '650px' : '450px'
                  }}
                >
                  <div
                    className="text-white flex-shrink-0"
                    style={{ backgroundColor: turno.sector.color, padding: '0.5rem 1rem' }}
                  >
                    <div className="flex items-center justify-between">
                      <span className="font-semibold opacity-90 whitespace-nowrap text-base">
                        {turno.sector.nombre}
                      </span>
                      <span className="px-2 py-0.5 bg-white/20 rounded-full whitespace-nowrap text-sm">
                        {turno.estado === 'llamado' ? 'Llamando...' : 'En atencion'}
                      </span>
                    </div>
                  </div>
                  <div className="flex justify-center items-center py-4">
                    <div
                      className="font-bold leading-tight text-center whitespace-nowrap"
                      style={{
                        fontSize: turnosActivos.length === 1 ? '5rem' :
                                 turnosActivos.length === 2 ? '4rem' :
                                 turnosActivos.length === 3 ? '3rem' :
                                 '2.5rem'
                      }}
                    >
                      {turno.numero}
                    </div>
                  </div>
                  <CardContent className="pt-0 pb-2 flex-shrink-0">
                    {turno.box && (
                      <div className="flex items-center justify-center mb-2">
                        <span
                          className="font-bold text-white shadow-lg text-center inline-block"
                          style={{
                            backgroundColor: turno.sector.color,
                            borderRadius: '25px',
                            fontSize: turnosActivos.length === 1 ? '1.3rem' :
                                     turnosActivos.length === 2 ? '1.1rem' :
                                     '1rem',
                            padding: '0.4rem 1.5rem',
                            minWidth: turnosActivos.length === 1 ? '180px' : '140px'
                          }}
                        >
                          {turno.box.nombre}
                        </span>
                      </div>
                    )}
                    <div className="flex items-center justify-center gap-1">
                      <span className="text-slate-600 text-sm">Hora:</span>
                      <span className="font-semibold text-slate-900 text-sm">
                        {new Date(turno.fechaLlamado).toLocaleTimeString('es-AR', {
                          hour: '2-digit',
                          minute: '2-digit'
                        })}
                      </span>
                    </div>
                  </CardContent>
                  {turno.estado === 'llamado' && (
                    <div className="absolute inset-0 pointer-events-none">
                      <div
                        className="absolute inset-0 animate-pulse opacity-10"
                        style={{ backgroundColor: turno.sector.color }}
                      />
                    </div>
                  )}
                </Card>
              ))}
            </div>
          )}
        </div>
      </div>
    )
  }

  // MONITOR INDIVIDUAL - CON VIDEOS (OTROS MONITORES - DISEÑO ANTERIOR)
  if (mostrarVideos) {
    return (
      <div className="h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 p-2 md:p-4 overflow-hidden flex flex-col">
        <div className="flex justify-between items-center py-1 px-4 flex-shrink-0">
          <Button
            variant="ghost"
            className="text-white/70 hover:text-white hover:bg-white/10"
            onClick={handleVolver}
          >
            ← Cambiar Monitor
          </Button>
          
          <div className="flex items-center gap-2">
            <span className="text-white/70 text-sm">
              {monitorData?.nombre}
            </span>
            <Button
              variant={audioEnabled ? "default" : "outline"}
              size="sm"
              className={audioEnabled 
                ? "bg-green-600 hover:bg-green-700 text-white" 
                : "border-white/30 text-white hover:bg-white/10"
              }
              onClick={() => audioEnabled ? setAudioEnabled(false) : unlockAudio()}
            >
              {audioEnabled ? (
                <Volume2 className="w-4 h-4" />
              ) : (
                <VolumeX className="w-4 h-4" />
              )}
            </Button>
          </div>
        </div>

        <div className="flex-1 flex gap-4 min-h-0">
          <div className="w-1/2 flex flex-col">
            <div className="flex-1 relative rounded-lg overflow-hidden bg-black">
              <VideoPlayer videos={videosAsignados} />
            </div>
          </div>
          
          <div className="w-1/2 flex flex-col">
            <div className="flex-1 bg-white/10 backdrop-blur-sm rounded-lg border border-white/20 p-4 overflow-hidden flex flex-col">
              <h2 className="text-white text-xl font-bold mb-3 text-center flex-shrink-0">
                Próximos Turnos
              </h2>
              <div className="flex-1 overflow-y-auto">
                {turnosActivos.length === 0 ? (
                  <div className="flex items-center justify-center h-full">
                    <Clock className="w-12 h-12 text-slate-400" />
                  </div>
                ) : (
                  <div className="grid gap-3">
                    {turnosActivos.map((turno) => (
                      <Card
                        key={turno.id}
                        className="overflow-hidden shadow-lg"
                        style={{ borderColor: turno.sector.color, backgroundColor: 'rgba(255,255,255,0.95)' }}
                      >
                        <div className="flex items-center p-3 gap-3">
                          <div
                            className="w-3 h-16 rounded-full flex-shrink-0"
                            style={{ backgroundColor: turno.sector.color }}
                          />
                          <div className="flex-1 min-w-0">
                            <div className="text-sm text-slate-500">{turno.sector.nombre}</div>
                            <div className="text-2xl font-bold text-slate-900">{turno.numero}</div>
                          </div>
                          {turno.box && (
                            <div className="text-right flex-shrink-0">
                              <div className="text-sm text-slate-500">Box</div>
                              <div className="font-semibold text-slate-900">{turno.box.nombre}</div>
                            </div>
                          )}
                          <div className="text-right flex-shrink-0">
                            <div className="text-xs text-slate-400">
                              {new Date(turno.fechaLlamado).toLocaleTimeString('es-AR', {
                                hour: '2-digit',
                                minute: '2-digit'
                              })}
                            </div>
                          </div>
                        </div>
                      </Card>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

        {turnosActivos.length > 0 && turnosActivos[0] && (
          <div className="mt-4 flex-shrink-0">
            <Card
              className="overflow-hidden shadow-2xl border-4"
              style={{
                borderColor: turnosActivos[0].sector.color,
                backgroundColor: 'rgba(255,255,255,0.98)'
              }}
            >
              <div className="flex items-center">
                <div
                  className="p-4 text-white flex items-center justify-center"
                  style={{ backgroundColor: turnosActivos[0].sector.color, minWidth: '200px' }}
                >
                  <div className="text-center">
                    <div className="text-lg font-semibold opacity-90">{turnosActivos[0].sector.nombre}</div>
                    <div className="text-4xl font-bold">{turnosActivos[0].numero}</div>
                  </div>
                </div>
                <div className="flex-1 p-4 flex items-center justify-between">
                  {turnosActivos[0].box && (
                    <div className="flex items-center gap-3">
                      <span className="text-slate-500">Diríjase a</span>
                      <span
                        className="px-6 py-2 font-bold text-white text-xl"
                        style={{
                          backgroundColor: turnosActivos[0].sector.color,
                          borderRadius: '25px'
                        }}
                      >
                        {turnosActivos[0].box.nombre}
                      </span>
                    </div>
                  )}
                  <div className="text-slate-600">
                    {turnosActivos[0].estado === 'llamado' && (
                      <span className="animate-pulse text-lg font-semibold">Llamando...</span>
                    )}
                  </div>
                </div>
              </div>
            </Card>
          </div>
        )}
      </div>
    )
  }

  // MONITOR INDIVIDUAL - SIN VIDEOS
  return (
    <div className="h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 p-2 md:p-4 overflow-hidden">
      <div className="h-full max-w-7xl mx-auto flex flex-col">
        <div className="flex justify-between items-center py-2 px-4">
          <Button
            variant="ghost"
            className="text-white/70 hover:text-white hover:bg-white/10"
            onClick={handleVolver}
          >
            ← Cambiar Monitor
          </Button>
          
          <Button
            variant={audioEnabled ? "default" : "outline"}
            className={audioEnabled 
              ? "bg-green-600 hover:bg-green-700 text-white" 
              : "border-white/30 text-white hover:bg-white/10"
            }
            onClick={() => audioEnabled ? setAudioEnabled(false) : unlockAudio()}
          >
            {audioEnabled ? (
              <>
                <Volume2 className="w-4 h-4 mr-2" />
                Sonido Activado
              </>
            ) : (
              <>
                <VolumeX className="w-4 h-4 mr-2" />
                Activar Sonido
              </>
            )}
          </Button>
        </div>

        <header className="text-center py-2 flex-shrink-0">
          {textosConfiguracion?.totemLogoUrl ? (
            <img
              src={textosConfiguracion.totemLogoUrl}
              alt="Logo Institución"
              className="h-8 md:h-12 mx-auto mb-2 object-contain"
              onError={(e) => {
                e.currentTarget.style.display = 'none'
              }}
            />
          ) : (
            <div className="flex justify-center mb-2">
              <MonitorIcon className="w-8 h-8 text-primary" />
            </div>
          )}
          <h1 className="text-2xl md:text-3xl font-bold text-white">
            {monitorData?.nombre || textosConfiguracion?.monitorTitulo || 'Monitor de Turnos'}
          </h1>
        </header>

        {loading ? (
          <div className="flex items-center justify-center py-20">
            <Loader2 className="w-16 h-16 animate-spin text-primary" />
          </div>
        ) : turnosActivos.length === 0 ? (
          <div className="flex-1 flex items-center justify-center">
            <Card className="bg-white/10 backdrop-blur-sm border-white/20">
              <CardContent className="p-8 md:p-12 text-center">
                <Clock className="w-16 h-16 mx-auto mb-3 text-slate-400" />
                <h2 className="text-2xl font-bold text-white mb-2">
                  Sin turnos en atencion
                </h2>
                <p className="text-slate-400">
                  Espere a que un operador llame al proximo turno
                </p>
              </CardContent>
            </Card>
          </div>
        ) : (
          <div className="flex-1 flex gap-4 md:gap-6 w-full items-center justify-center px-4">
            {turnosActivos.map((turno) => (
              <Card
                key={turno.id}
                className="overflow-hidden shadow-2xl border-2 relative flex flex-col"
                style={{
                  borderColor: turno.sector.color,
                  backgroundColor: 'rgba(255,255,255,0.95)',
                  width: turnosActivos.length === 1 ? 'auto' : 
                         turnosActivos.length === 2 ? '48%' : 
                         turnosActivos.length === 3 ? '32%' : '24%',
                  minWidth: turnosActivos.length === 1 ? '450px' : '280px',
                  maxWidth: turnosActivos.length === 1 ? '600px' : '400px'
                }}
              >
                <div
                  className="p-3 md:p-4 text-white flex-shrink-0"
                  style={{ backgroundColor: turno.sector.color }}
                >
                  <div className="flex items-center justify-between">
                    <span className="text-base md:text-lg font-semibold opacity-90 whitespace-nowrap">
                      {turno.sector.nombre}
                    </span>
                    <span className="px-3 py-1 bg-white/20 rounded-full text-sm whitespace-nowrap">
                      {turno.estado === 'llamado' ? 'Llamando...' : 'En atencion'}
                    </span>
                  </div>
                </div>
                <div className="flex justify-center items-center py-8 md:py-12">
                  <div
                    className="font-bold leading-tight text-center whitespace-nowrap"
                    style={{
                      fontSize: turnosActivos.length === 1 ? '7rem' :
                               turnosActivos.length === 2 ? '5.5rem' :
                               turnosActivos.length === 3 ? '4rem' :
                               '3rem'
                    }}
                  >
                    {turno.numero}
                  </div>
                </div>
                <CardContent className="pt-0 pb-4 flex-shrink-0">
                  {turno.box && (
                    <div className="flex items-center justify-center mb-3">
                      <span
                        className="px-12 py-3 font-bold text-white shadow-lg text-center inline-block"
                        style={{
                          backgroundColor: turno.sector.color,
                          borderRadius: '25px',
                          fontSize: turnosActivos.length === 1 ? '1.75rem' :
                                   turnosActivos.length === 2 ? '1.5rem' :
                                   '1.25rem',
                          minWidth: turnosActivos.length === 1 ? '300px' : '220px'
                        }}
                      >
                        {turno.box.nombre}
                      </span>
                    </div>
                  )}
                  <div className="flex items-center justify-center gap-2">
                    <span className="text-slate-600 text-base">Hora:</span>
                    <span
                      className="font-semibold text-slate-900"
                      style={{
                        fontSize: turnosActivos.length === 1 ? '1.25rem' :
                                 turnosActivos.length === 2 ? '1.1rem' :
                                 '1rem'
                      }}
                    >
                      {new Date(turno.fechaLlamado).toLocaleTimeString('es-AR', {
                        hour: '2-digit',
                        minute: '2-digit'
                      })}
                    </span>
                  </div>
                </CardContent>
                {turno.estado === 'llamado' && (
                  <div className="absolute inset-0 pointer-events-none">
                    <div
                      className="absolute inset-0 animate-pulse opacity-10"
                      style={{ backgroundColor: turno.sector.color }}
                    />
                  </div>
                )}
              </Card>
            ))}
          </div>
        )}
      </div>
    </div>
  )
}
